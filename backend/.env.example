# SentinelAI Backend Environment Variables

# Application
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Database (defaults to SQLite for development)
DATABASE_URL=sqlite:///./sentinelai.db

# Botpress Configuration (optional — can be set per-resource)
# BOTPRESS_TIMEOUT_SECONDS=30
# BOTPRESS_POLL_INTERVAL_SECONDS=1.0
# BOTPRESS_MAX_RETRIES=3

# Security (not used in open-source version)
# SECRET_KEY=your-secret-key-here
